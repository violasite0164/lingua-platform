{
  "name": "lingua-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/patch-next-write-atomic.mjs",
    "predev": "node scripts/patch-next-write-atomic.mjs && NEXT_DEV_TURBOPACK=1 node scripts/prep-next.mjs",
    "dev": "NEXT_TELEMETRY_DISABLED=1 node -r ./scripts/next-dev-prelude.cjs node_modules/next/dist/bin/next dev --turbopack",
    "dev:webpack": "node scripts/patch-next-write-atomic.mjs && node scripts/prep-next.mjs && NEXT_TELEMETRY_DISABLED=1 node -r ./scripts/next-dev-prelude.cjs node_modules/next/dist/bin/next dev",
    "dev:clean": "rm -rf .next && node scripts/patch-next-write-atomic.mjs && NEXT_DEV_TURBOPACK=1 node scripts/prep-next.mjs && NEXT_TELEMETRY_DISABLED=1 node -r ./scripts/next-dev-prelude.cjs node_modules/next/dist/bin/next dev --turbopack",
    "dev:clean:webpack": "rm -rf .next && node scripts/patch-next-write-atomic.mjs && node scripts/prep-next.mjs && NEXT_TELEMETRY_DISABLED=1 node -r ./scripts/next-dev-prelude.cjs node_modules/next/dist/bin/next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start",
    "lint": "next lint --max-warnings 0",
    "audit:quiz": "python3 supabase/validate_question_seeds.py && python3 supabase/audit_question_bank.py",
    "export:questions-review": "python3 supabase/export_questions_for_review.py",
    "type-check": "tsc --noEmit",
    "warmup": "node scripts/warmup.mjs",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "dependencies": {
    "@cloudflare/stream-react": "^1.9.3",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@stripe/stripe-js": "^5.7.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.5",
    "@tiptap/extension-highlight": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.503.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.56.0",
    "react-player": "^2.16.0",
    "recharts": "^2.15.3",
    "stripe": "^17.7.0",
    "tailwind-merge": "^2.6.0",
    "wavesurfer.js": "^7.9.5",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.5",
    "@types/node": "^22.15.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.26.0",
    "eslint-config-next": "15.5.15",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
