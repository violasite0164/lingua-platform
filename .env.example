# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ─── Cloudflare Stream ───────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_STREAM_API_TOKEN=your-api-token
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=customer-xxx.cloudflarestream.com

# ─── App ─────────────────────────────────────────────────────────────────────
# OAuth redirect must match this URL (also add /auth/callback in Supabase → Authentication → URL).
# Production: https://your-domain.com   Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# YouTube 首頁背景：預設使用 youtube.com。設為 true 則改用 youtube-nocookie（較嚴格隱私，但有環境會出現「Sign in to confirm you are not a bot」）。
# NEXT_PUBLIC_YOUTUBE_EMBED_USE_NOCOOKIE=true
